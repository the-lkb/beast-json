# Doxyfile 1.9.1

PROJECT_NAME           = "Beast JSON"
PROJECT_NUMBER         = "1.0.5"
PROJECT_BRIEF          = "The fastest C++20 JSON library you can drop into any project — single header, zero dependencies."

OUTPUT_DIRECTORY       = docs/api/
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English

# Build Related
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_PRIV_VIRTUAL   = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO
EXTRACT_ANON_NSPACES   = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = NO
HIDE_IN_BODY_DOCS      = NO
INTERNAL_DOCS          = NO

# Input Related
INPUT                  = include/qbuem_json/qbuem_json.hpp docs/TECHNICAL_REFERENCE.md docs/GETTING_STARTED.md docs/TEST_CASES.md
FILE_PATTERNS          = *.hpp *.h *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       =
USE_MDFILE_AS_MAINPAGE = docs/TECHNICAL_REFERENCE.md

# HTML Related
HTML_OUTPUT            = reference
HTML_FILE_EXTENSION    = .html
HTML_HEADER            =
HTML_FOOTER            =
HTML_STYLESHEET        =
HTML_EXTRA_STYLESHEET  = docs/doxygen_custom.css
HTML_EXTRA_FILES       =
HTML_COLORSTYLE_HUE    = 183
HTML_COLORSTYLE_SAT    = 100
HTML_COLORSTYLE_GAMMA  = 100

# Source Browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES

# Warning Related
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = NO

# Preprocessor
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = include/
PREDEFINED             = "BEAST_INLINE=inline" "BEAST_HAS_CONCEPTS=1" "BEAST_UNLIKELY(x)=" "BEAST_LIKELY(x)="

# Graph
HAVE_DOT               = NO
GENERATE_LATEX         = NO
